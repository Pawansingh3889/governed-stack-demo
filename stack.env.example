# Governed-stack configuration. Copy to stack.env and edit.
#
# Defaults run the fully offline demo (SQLite + hashing embedder + validate-only
# KQL). Change any line to point a server at real on-prem infrastructure; the
# governance applies identically either way. {root} expands to this folder.

# ----- gateway (auth + OPA/Rego policy, the front door) -----
# Open WebUI talks to the gateway; mcpo and OPA are internal.
GATEWAY_PORT=8765
MCPO_PORT=8766
OPA_PORT=8181
# token:role pairs. The caller sends its token; the role drives the policy.
# Demo tokens — replace with real ones (or wire OIDC) for anything beyond local.
GATEWAY_TOKENS=viewer-tok:viewer,analyst-tok:analyst,finance-tok:finance,manager-tok:manager
# Per-role data budgets are policy now: set budget_bytes per role in
# policy/roles.json (0 = unlimited). The gateway tracks cumulative response bytes
# and OPA denies once a role is over budget.
# Audit export (OpenTelemetry). Set an OTLP endpoint to ship every decision as a
# span to a collector (Jaeger / Grafana Tempo / an OTLP gateway). Blank writes
# spans to logs/otel-spans.jsonl so the export is visible with no collector.
OTEL_EXPORTER_OTLP_ENDPOINT=

# Chat model Open WebUI defaults to (must be a chat model, not an embedder).
CHAT_MODEL=qwen3:14b

# ----- sql-steward (governed SQL) -----
# Demo: bundled SQLite. Real example:
#   postgresql+psycopg://user:pass@host:5432/dbname
SQL_STEWARD_DB_URL=sqlite:///{root}/data/sql/demo.db
SQL_STEWARD_LAYER={root}/data/sql/semantic.yaml

# ----- doc-steward (governed RAG) -----
DOC_STEWARD_CORPUS={root}/data/docs/corpus.json
# Embedder: hashing (offline, deterministic, default) | ollama (local semantic).
DOC_STEWARD_EMBED=hashing
DOC_STEWARD_OLLAMA_HOST=http://localhost:11434
DOC_STEWARD_OLLAMA_MODEL=nomic-embed-text

# ----- schema-scout (schema discovery) -----
# Optional. Point at a generated catalog.json to expose discovery tools
# (list_tables / describe_table / find_join_path). Blank to disable the tool.
# Generate the demo catalog with: python -m schema_scout.cli demo --out data/schema
SCHEMA_SCOUT_CATALOG={root}/data/schema/catalog.json

# ----- thread-recall (governed memory) -----
# Optional. Set a SQLite path to enable remember/recall tools. PII is masked on
# write (mask=1) so the long-term memory never retains raw PII. Blank to disable.
THREAD_RECALL_DB={root}/logs/recall-mem.db
THREAD_RECALL_MASK=1
THREAD_RECALL_EMBED=hashing

# ----- kql-sop (governed KQL) -----
# Leave blank to validate-and-refuse only (no cluster needed). Set both to run
# validated queries against a real Azure Data Explorer / Fabric KQL cluster.
KQL_SOP_CLUSTER=
KQL_SOP_DATABASE=
